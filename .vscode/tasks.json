{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: restore",
      "type": "process",
      "command": "dotnet",
      "args": ["restore", "${workspaceFolder}/src/SectorForge.slnx"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/SectorForge.slnx",
        "--no-restore"
      ],
      "dependsOn": "dotnet: restore",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/SectorForge.Api/SectorForge.Api.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build collector",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/SectorForge.Collector/SectorForge.Collector.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: test",
      "type": "process",
      "command": "dotnet",
      "args": ["test", "${workspaceFolder}/src/SectorForge.slnx"],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "web: install",
      "type": "shell",
      "command": "npx --yes pnpm@latest --dir \"${workspaceFolder}/src/SectorForge.Web\" install",
      "problemMatcher": []
    },
    {
      "label": "web: dev server",
      "type": "shell",
      "command": "npx --yes pnpm@latest --dir \"${workspaceFolder}/src/SectorForge.Web\" dev --host localhost --port 5173",
      "options": {
        "env": {
          "VITE_API_BASE_URL": "http://localhost:5221"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*>\\s+vite(?:\\s|$)",
          "endsPattern": "^\\s*(?:➜\\s+)?Local:\\s+http://localhost:5173/?\\s*$"
        }
      }
    },
    {
      "label": "web: build",
      "type": "shell",
      "command": "npx --yes pnpm@latest --dir \"${workspaceFolder}/src/SectorForge.Web\" build",
      "group": "build",
      "problemMatcher": [
        {
          "base": "$tsc",
          "fileLocation": ["relative", "${workspaceFolder}/src/SectorForge.Web"]
        },
        {
          "owner": "vite",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.+):(\\d+):(\\d+):\\s+(ERROR|error|WARNING|warning):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        }
      ]
    },
    {
      "label": "web: lint",
      "type": "shell",
      "command": "npx --yes pnpm@latest --dir \"${workspaceFolder}/src/SectorForge.Web\" lint",
      "problemMatcher": []
    },
    {
      "label": "sectorforge: dev script",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/dev.ps1\"",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "sectorforge: clean",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/clean.ps1\"",
      "problemMatcher": []
    },
    {
      "label": "sectorforge: verify",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/tools/verify.ps1\"",
      "group": "test",
      "problemMatcher": ["$msCompile", "$tsc"]
    }
  ]
}
